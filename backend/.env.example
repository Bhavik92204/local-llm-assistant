# Ollama HTTP API (default install)
# Prefer 127.0.0.1 on Windows to avoid IPv6 localhost (::1) vs IPv4 listener mismatches
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Model pulled in Ollama, e.g. `ollama pull llama3` or `ollama pull mistral`
OLLAMA_MODEL=llama3

# Comma-separated origins for CORS (Next.js dev — include every port/host you use in Chrome)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Max tool round-trips per user message (prevents runaway loops)
MAX_TOOL_ROUNDS=5

# Assistant personality preset (keys in app/config/personality.py PRESETS)
# ASSISTANT_PERSONALITY=jarvis_default
