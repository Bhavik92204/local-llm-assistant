# --- Environment & secrets (never commit) ---
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
*.pem

# --- Python ---
backend/.venv/
backend/venv/
backend/ENV/
.venv/
venv/
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
pip-wheel-metadata/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/
.dmypy.json

# --- Node / Next.js ---
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- OS ---
.DS_Store
Thumbs.db
Desktop.ini

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo

# --- Local app data (generated at runtime) ---
backend/data/settings.json
backend/data/*.db
backend/data/*.db-wal
backend/data/*.db-shm

# TypeScript
*.tsbuildinfo

# --- Misc ---
*.log
.cache/
